{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "useDefineForClassFields": false,
    "lib": [
      "ES2022",
      "dom"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@ui/badge": [
        "libs/components/badge/src/index.ts"
      ],
      "@ui/button": [
        "libs/components/button/src/index.ts"
      ],
      "@ui/core": [
        "libs/core/src/index.ts"
      ],
      "@ui/date-picker": [
        "libs/components/date-picker/src/index.ts"
      ],
      "@ui/icon": [
        "libs/components/icon/src/index.ts"
      ],
      "@ui/input": [
        "libs/components/input/src/index.ts"
      ],
      "@ui/pagination": [
        "libs/components/pagination/src/index.ts"
      ],
      "@ui/patterns": [
        "libs/patterns/src/index.ts"
      ],
      "@ui/select": [
        "libs/components/select/src/index.ts"
      ],
      "@ui/tab": [
        "libs/components/tab/src/index.ts"
      ],
      "@ui/theme": [
        "libs/theme/src/index.ts"
      ],
      "@ui/tokens": [
        "libs/tokens/src/index.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
